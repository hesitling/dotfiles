#!/bin/bash

append_path() {
  case ":$PATH:" in
  *:"$1":*) ;;
  *)
    PATH="${PATH:+$PATH:}$1"
    ;;
  esac
}

export EDITOR='{{ .user.programs.editor }}'
export DMENU='{{ .user.programs.dmenu }}'
export DMENU_GUI='{{ .user.programs.dmenuGUI }}'
export LANG='en_US.UTF-8'
export LESSHISTSIZE=0
export LESSHISTFILE=/dev/null
export MANPAGER='{{ .user.programs.editor }} +Man!'

export XDG_CACHE_HOME="${HOME}/.cache"
export XDG_CONFIG_HOME="${HOME}/.config"
export XDG_DATA_HOME="${HOME}/.local/share"
export XDG_STATE_HOME="${HOME}/.local/state"
export XKB_DEFAULT_LAYOUT='cn'
#export XKB_DEFAULT_VARIANT=''

export XCURSOR_PATH="${XCURSOR_PATH}:/usr/share/icons:${HOME}/.icons:${XDG_DATA_HOME}/icons"
export XCURSOR_SIZE='{{ .user.device.cursorSize }}'
export XCURSOR_THEME='{{ .user.themes.cursor }}'
export GTK_THEME='{{ .user.themes.gtk }}'
export ICON_THEME='{{ .user.themes.icon }}'

export PASSWORD_STORE_CLIP_TIME=15
export PASSWORD_STORE_GENERATED_LENGTH=32

export NPM_HOME="${XDG_DATA_HOME}/npm"
export NPM_PREFIX="${NPM_HOME}/data"
export NODE_PATH="${NPM_PREFIX}/lib/node_modules/:${NODE_PATH}"

export CMAKE_COLOR_DIAGNOSTICS=1
export CMAKE_EXPORT_COMPILE_COMMANDS=1
export CMAKE_GENERATOR=Ninja

export DOTNET_HOME="${HOME}/.dotnet"
export DOTNET_TOOLS="${DOTNET_HOME}/tools"
# export NUGET_HOME="${HOME}/.nuget"

export PNPM_HOME="${XDG_DATA_HOME}/pnpm"

export UV_HOME="${XDG_DATA_HOME}/uv"
export UV_CACHE_DIR="${XDG_CACHE_HOME}/uv"
export UV_PYTHON_DIR="${UV_HOME}/python"
export UV_TOOL_DIR="${UV_HOME}/tool"

export OPENCODE_EXPERIMENTAL_LSP_TOOL='true'
export OPENCODE_DISABLE_LSP_DOWNLOAD='true'

export GOPATH="${XDG_DATA_HOME}/go"

export DOCKER_HOST="unix://${XDG_RUNTIME_DIR}/podman/podman.sock"

append_path "${HOME}/.local/bin"
append_path "${PYTHONUSERBASE}/bin"
#append_path "${BUN_INSTALL}/bin"
append_path "${NPM_PREFIX}/bin"
append_path "${DOTNET_TOOLS}"
append_path "${PNPM_HOME}"
append_path "${PNPM_HOME}/bin"
append_path "${GOPATH}/bin"
