#!/bin/bash

LD_LIBRARY_PATH+=":${CPKG_PREFIX}/lib"
export LD_LIBRARY_PATH

alias diffu='diff --color=auto -U3'
alias duu='du -hd 1'
alias fork='foot -D "$(pwd)" 1>&2 2>/dev/null &' #@reference_tag(terminal)
alias grepu='grep -inrI --color=auto'
alias ls='ls --color=auto'
alias lh='ls -ahlpQ --color=auto'
alias mountu='sudo mount -o X-mount.owner="${USER}",X-mount.group=users,X-mount.mode=775,uid="${USER}",gid=users'
alias nv='nvim'
alias para='parallel-moreutils'
alias psu='ps -u "${USER}"'
alias randnum='tr -cd "0-9" < /dev/urandom | head -c'
alias rem='remind -n ~/doc/remind/all.remind' #@reference_tag(reminders)
alias shred='shred -uz -n3 --random-source=/dev/urandom'
alias weather='curl wttr.in/ganzhou'

scd() {
    local s=''
    [[ -z "${1}" ]] || s="-maxdepth ${1}"
    cd "$(find -mindepth 1 $s -type d | "${DMENU}")"
}

safe() {
    alias cp='cp -i'
    alias mv='mv -i'
    alias rm='rm -I'
}
unsafe() {
    unalias cp
    unalias mv
    unalias rm
}

safe
