[main]
dpi-aware = auto
exit-on-keyboard-focus-loss = no
font = monospace:size=13
match-mode = fzf
#icon-theme =
icons-enabled = no
inner-pad = 4
lines = 20
layer = overlay
prompt = '> '
show-actions = no
terminal = '{{ .user.programs.terminal }} --'
width = 45

[border]
width = 1
radius = 0

[colors]
background = 1a1b26ff
border = b16286ff
match = fe8019ff
text = ebdbb2ff
prompt = 586e75ff
input = ebdbb2ff
selection = ebdbb2ff
selection-match = fe8019ff
selection-text = 282828ff

[dmenu]
mode = text
exit-immediately-if-empty = no

[key-bindings]
cancel = Escape
execute = Return KP_Enter
execute-or-next = Tab

