{{- $terminal := .user.colors.terminal }}
[general]
live_config_reload = false
ipc_socket = false

[terminal]
shell = '/bin/tmux'

[window]
dynamic_title = false

[scrolling]
history = 1024
multiplier = 5

[font]
builtin_box_drawing = true
size = 14

[colors]
draw_bold_text_with_bright_colors = true
[colors.primary]
background = '#{{ $terminal.normal.background }}'
foreground = '#{{ $terminal.normal.foreground }}'
[colors.normal]
black = '#{{ $terminal.normal.background }}'
red = '#{{ $terminal.normal.red }}'
green = '#{{ $terminal.normal.green }}'
yellow = '#{{ $terminal.normal.yellow }}'
blue = '#{{ $terminal.normal.blue }}'
magenta = '#{{ $terminal.normal.magenta }}'
cyan = '#{{ $terminal.normal.cyan }}'
white = '#{{ $terminal.normal.white }}'
[colors.bright]
black = '#{{ $terminal.bright.black }}'
red = '#{{ $terminal.bright.red }}'
green = '#{{ $terminal.bright.green }}'
yellow = '#{{ $terminal.bright.yellow }}'
blue = '#{{ $terminal.bright.blue }}'
magenta = '#{{ $terminal.bright.magenta }}'
cyan = '#{{ $terminal.bright.cyan }}'
white = '#{{ $terminal.bright.white }}'

[cursor]
#style = {shape = 'Block', blinking = 'Off'}
thickness = 1.0

[mouse]
hide_when_typing = true
